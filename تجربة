#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int numero, palpite, tentativas;
    char jogar_novamente;

    srand(time(NULL));

    do {
        numero = rand() % 10 + 1;
        tentativas = 0;

        printf("\nAdivinhe o numero de 1 a 10\n");

        while (1) {
            printf("Digite um numero: ");

            // التحقق من الإدخال
            if (scanf("%d", &palpite) != 1) {
                printf("Entrada invalida! Digite apenas numeros.\n");
                while (getchar() != '\n'); // تنظيف الإدخال
                continue;
            }

            tentativas++;

            if (palpite == numero) {
                printf("Correto! Voce ganhou em %d tentativas\n", tentativas);
                break;
            } else if (palpite < numero) {
                printf("O numero e maior\n");
            } else {
                printf("O numero e menor\n");
            }
        }

        printf("Jogar novamente? (s/n): ");
        scanf(" %c", &jogar_novamente);

    } while (jogar_novamente == 's' || jogar_novamente == 'S');

    printf("Fim do jogo\n");
    return 0;
}
